# Goal: 目标位置请求
builtin_interfaces/Time stamp      # 动作开始时间
int64[] target_axes                # 目标轴号列表
float64[] target_positions         # 目标位置列表
float64[] speed                    # 移动速度数组
float64[] acceleration             # 加速度数组
float64[] deceleration             # 减速度数组
---
# Result: 最终结果
builtin_interfaces/Time end_time   # 动作完成时间
bool success                       # 是否成功
string message                     # 状态消息
float64[] final_positions          # 最终到达的位置
---
# Feedback: 过程反馈
float64 progress                   # 移动进度 (0.0 ~ 1.0)
float64[] current_positions        # 当前位置
float64[] current_velocities       # 当前速度
string current_status              # 当前状态描述
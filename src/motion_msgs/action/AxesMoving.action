# Goal: 目标位置请求
int64[] target_axes                # 目标轴号列表
float64[] target_positions         # 目标位置列表
---
# Result: 最终结果
bool success                       # 是否成功
string message                     # 状态消息
float64[] final_positions          # 最终到达的位置
float64 duration                   # 动作持续时间（秒）
---
# Feedback: 过程反馈
float64 progress                   # 移动进度 (0.0 ~ 1.0)
float64[] current_positions        # 当前位置
float64[] current_velocities       # 当前速度
float64 elapsed_time               # 已执行时间（秒）